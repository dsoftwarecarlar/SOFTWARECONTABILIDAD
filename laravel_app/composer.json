{
    "name": "contabilidad/portal-operativo-laravel",
    "type": "project",
    "description": "Laravel coexistence scaffold for SOFTWARECONTABILIDAD.",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "nunomaduro/collision": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "dev": [
            "@php artisan serve"
        ],
        "lint:config": [
            "@php -l routes/web.php",
            "@php -l config/cxp.php",
            "@php -l config/python.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

